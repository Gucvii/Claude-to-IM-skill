{
  "name": "@gucvii/claude-to-im-skill",
  "version": "0.1.1",
  "description": "Claude Code Skill: Bridge IM platforms (Telegram, Discord, Feishu, QQ, WeChat) to Claude Code sessions",
  "type": "module",
  "author": "gucvii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gucvii/claude-to-im-skill.git"
  },
  "bugs": {
    "url": "https://github.com/Gucvii/claude-to-im-skill/issues"
  },
  "homepage": "https://github.com/Gucvii/claude-to-im-skill#readme",
  "keywords": [
    "claude",
    "claude-code",
    "telegram",
    "discord",
    "feishu",
    "lark",
    "qq",
    "wechat",
    "im-bridge",
    "skill"
  ],
  "files": ["dist", "src", "scripts", "SKILL.md", "CLAUDE.md", "config.env.example"],
  "scripts": {
    "build": "node scripts/build.js",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/main.ts",
    "weixin:login": "node --import tsx src/weixin-login.ts",
    "test": "CTI_HOME=$(mktemp -d) node --test --test-concurrency=1 --import tsx --test-timeout=15000 src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.62",
    "@gucvii/claude-to-im": "^0.1.0",
    "qrcode": "^1.5.4"
  },
  "optionalDependencies": {
    "@openai/codex-sdk": "^0.110.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
